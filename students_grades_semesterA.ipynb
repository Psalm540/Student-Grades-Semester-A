import sqlite3
import random
import os
!pip install faker
from faker import Faker

# Define the database path based on how it appears in the Colab environment
db_path = "/content/C:\\Users\\Owner\\Desktop\\student_grades_semesterA.db"
journal_path = db_path + "-journal"

# -------------------------
# Remove database files if they exist (to clear any locks or corruption)
# -------------------------
if os.path.exists(db_path):
    os.remove(db_path)
    print(f"Removed existing database file: {db_path}")
if os.path.exists(journal_path):
    os.remove(journal_path)
    print(f"Removed existing database journal file: {journal_path}")

# Connect to database
conn = sqlite3.connect(db_path)
cursor = conn.cursor()

# -------------------------
# Drop Tables if they exist (to ensure a clean slate for re-runs within a single session)
# -------------------------
cursor.execute("DROP TABLE IF EXISTS Grades;")
cursor.execute("DROP TABLE IF EXISTS Assessments;")
cursor.execute("DROP TABLE IF EXISTS Students;")
cursor.execute("DROP TABLE IF EXISTS Modules;")

# -------------------------
# Create Tables
# -------------------------
cursor.execute("""
    CREATE TABLE Students (
        student_id INTEGER PRIMARY KEY AUTOINCREMENT,
        full_name TEXT NOT NULL,
        gender TEXT NOT NULL,
        date_of_birth DATE,
        enrollment_year INTEGER
    );
""")

cursor.execute("""
    CREATE TABLE Modules (
        module_id INTEGER PRIMARY KEY AUTOINCREMENT,
        module_name TEXT NOT NULL UNIQUE,
        credit_units INTEGER,
        lecturer_name TEXT
    );
""")

cursor.execute("""
    CREATE TABLE Assessments (
        assessment_id INTEGER PRIMARY KEY AUTOINCREMENT,
        module_id INTEGER NOT NULL,
        assessment_type TEXT NOT NULL,
        max_score INTEGER,
        FOREIGN KEY (module_id) REFERENCES Modules(module_id)
    );
""")

cursor.execute("""
    CREATE TABLE Grades (
        grade_id INTEGER PRIMARY KEY AUTOINCREMENT,
        student_id INTEGER NOT NULL,
        assessment_id INTEGER NOT NULL,
        score INTEGER,
        FOREIGN KEY (student_id) REFERENCES Students(student_id),
        FOREIGN KEY (assessment_id) REFERENCES Assessments(assessment_id)
    );
""")

conn.commit()

fake = Faker()

# -------------------------
# Insert Students (500)
# -------------------------
for _ in range(500):
    cursor.execute("""
        INSERT INTO Students (full_name, gender, date_of_birth, enrollment_year)
        VALUES (?, ?, ?, ?)
    """, (
        fake.name(),
        random.choice(["Male", "Female"]),
        fake.date_of_birth(minimum_age=18, maximum_age=30),
        random.randint(2021, 2025)
    ))

# -------------------------
# Insert Modules (5)
# -------------------------
modules = [
    ("Machine Learning", 20, "Dr. Smith"),
    ("Data Mining", 15, "Dr. Johnson"),
    ("Statistics for DS", 20, "Dr. Brown"),
    ("Python Programming", 15, "Dr. White"),
    ("Big Data Analytics", 20, "Dr. Green")
]

cursor.executemany("""
    INSERT INTO Modules (module_name, credit_units, lecturer_name)
    VALUES (?, ?, ?)
""", modules)

# -------------------------
# Insert Assessments (3 per module)
# -------------------------
cursor.execute("SELECT module_id FROM Modules")
module_ids = cursor.fetchall()

assessment_types = ["Exam", "Coursework", "Project"]

for module in module_ids:
    for assess in assessment_types:
        cursor.execute("""
            INSERT INTO Assessments (module_id, assessment_type, max_score)
            VALUES (?, ?, ?)
        """, (module[0], assess, 100))

# -------------------------
# Insert Grades (1000+ rows)
# -------------------------
cursor.execute("SELECT student_id FROM Students")
students = cursor.fetchall()

cursor.execute("SELECT assessment_id FROM Assessments")
assessments = cursor.fetchall()

for student in students:
    for assessment in assessments:
        cursor.execute("""
            INSERT INTO Grades (student_id, assessment_id, score)
            VALUES (?, ?, ?)
        """, (
            student[0],
            assessment[0],
            random.randint(30, 100)
        ))

# Commit and close
conn.commit()
conn.close()

print("Database successfully populated with 1000+ records.")
